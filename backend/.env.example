# Copiá este archivo a .env y completá los valores.
# El archivo .env no se sube a Git (está en .gitignore).

# PostgreSQL (local, Neon, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Conexión directa (obligatoria con Prisma Migrate / db push en Neon).
# - Neon: en el dashboard, "Connection string" → elegí "Direct" (host SIN `-pooler`).
# - Postgres local: podés repetir el mismo valor que DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# JWT: usá un secreto largo y aleatorio (mínimo 16 caracteres)
JWT_SECRET="cambiar-por-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="365d"

PORT=4000
CORS_ORIGIN="http://localhost:5173"

# Opcional: credenciales del admin creado por `npm run db:seed`
SEED_ADMIN_EMAIL="admin@clinica.com"
SEED_ADMIN_PASSWORD="Admin123!"

# --- WhatsApp Business (Meta Cloud API) ---
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0
# Legacy (ya no se usa SHORT_NOTICE); solo recordatorio 24 h antes del turno
WHATSAPP_SHORT_NOTICE_DELAY_MINUTES=5
# Plantilla 24 h (7 vars + wa.me): recordatorio_turno_24hs_contacto
WHATSAPP_REMINDER_TEMPLATE_24H_NAME=recordatorio_turno_24hs_contacto
# Alternativa sin contacto (6 vars): recordatorio_turno_24h
WHATSAPP_REMINDER_TEMPLATE_NAME=
WHATSAPP_REMINDER_TEMPLATE_LANGUAGE=es_AR
CLINIC_NAME="LogoCen"
CLINIC_ADDRESS="Av. Corrientes 1234, CABA (actualizar con dirección real)"
# wa.me en {{7}} de recordatorio_turno_24hs_contacto
CLINIC_CONTACT_PHONE="11 4154-0215"

# Cron: POST /api/internal/whatsapp/reminders/run con header X-Cron-Secret
CRON_SECRET=
