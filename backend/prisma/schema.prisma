generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  /// App / runtime (Neon: URL con `-pooler` está bien).
  url       = env("DATABASE_URL")
  /// Migraciones y `db push`: usá conexión **directa** (sin pooler). Si no, Prisma puede fallar con P1002 (advisory lock).
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  SPECIALIST
}

enum AppointmentStatus {
  RESERVED
  /// Paciente confirmó asistencia (WhatsApp o manual vía cambio de estado en el turno).
  CONFIRMADO
  RESERVADO
  ATTENDED
  AUSENTE_CON_AVISO
  AUSENTE_SIN_AVISO
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum AppointmentPaymentMethod {
  TRANSFER_TO_LOGOCEN
  TRANSFER_TO_SPECIALIST
  CASH_TO_LOGOCEN
}

/// Origen de la confirmación del paciente (WhatsApp se usará cuando esté integrado).
enum PatientConfirmationSource {
  MANUAL
  WHATSAPP
}

/// Tipo de recordatorio WhatsApp según anticipación del turno.
enum WhatsappReminderKind {
  /// Envío programado 24 h antes del inicio del turno.
  STANDARD_24H
  /// Turno agendado con menos de 24 h: solicitud de confirmación inmediata.
  SHORT_NOTICE
}

enum WhatsappReminderStatus {
  SCHEDULED
  SENT
  FAILED
  SKIPPED
  CANCELLED
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum FinanceExpenseType {
  FIXED_MONTHLY
  MONTHLY_VARIABLE
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  /// Copia en claro solo para consulta del administrador (se actualiza al crear/cambiar clave del especialista).
  adminVisiblePassword String?
  role         Role
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  specialist   Specialist?
}

model Specialist {
  id               String        @id @default(uuid())
  userId           String        @unique
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String
  specialty        String
  /// URL de foto de perfil (p. ej. almacenamiento externo o data URL acotada)
  profilePhotoUrl  String?
  licenseNumber    String?
  phone            String?
  consultationFee  Decimal?      @db.Decimal(12, 2)
  /// Alquiler mensual del consultorio (LogoCen cobra a fin de mes; ingreso administrativo).
  monthlyConsultorioRent Decimal? @db.Decimal(12, 2)
  transferAlias    String?
  /// Notas internas (admin): consideraciones operativas del profesional.
  considerations   String?       @db.Text
  active           Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  documents     SpecialistDocument[]
  appointments  Appointment[]
  fixedAppointmentSeries FixedAppointmentSeries[]
  patients      Patient[]
  clinicalHistoryEntries ClinicalHistoryEntry[]
  availabilities SpecialistAvailability[]
  consultorioRentMonths SpecialistConsultorioRentMonth[]
}

/// Alquiler de consultorio por mes calendario (se genera automático: copia el mes anterior o el monto base del especialista).
model SpecialistConsultorioRentMonth {
  id             String     @id @default(uuid())
  specialistId   String
  specialist     Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  /// Mes "YYYY-MM"
  yearMonth      String
  amount         Decimal    @db.Decimal(12, 2)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([specialistId, yearMonth])
  @@index([yearMonth])
}

model SpecialistDocument {
  id           String     @id @default(uuid())
  specialistId String
  specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  fileName     String
  mimeType     String
  /// Ruta relativa bajo `uploads/` (p. ej. specialist-documents/{id}/archivo.pdf)
  storagePath  String
  fileSize     Int
  createdAt    DateTime   @default(now())

  @@index([specialistId])
}

model SpecialistAvailability {
  id           String     @id @default(uuid())
  specialistId String
  specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  weekday      Weekday
  startTime    String
  endTime      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([specialistId, weekday])
}

model Patient {
  id           String        @id @default(uuid())
  firstName    String
  lastName     String
  email        String
  phone        String?
  documentId   String?
  birthDate    DateTime?
  notes        String?
  specialistId String?
  specialist   Specialist?   @relation(fields: [specialistId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  fixedAppointmentSeries FixedAppointmentSeries[]
  clinicalHistoryEntries ClinicalHistoryEntry[]
  whatsappReminders      WhatsappReminder[]

  @@index([specialistId])
}

/// Cola de recordatorios / confirmación por WhatsApp (Meta Cloud API).
model WhatsappReminder {
  id              String                 @id @default(uuid())
  /// ID de turno en API (`uuid` o `fixed:{seriesId}:{YYYY-MM-DD}`).
  appointmentRef  String
  patientId       String
  patient         Patient                @relation(fields: [patientId], references: [id], onDelete: Cascade)
  kind            WhatsappReminderKind
  status          WhatsappReminderStatus @default(SCHEDULED)
  scheduledSendAt DateTime
  sentAt          DateTime?
  waMessageId     String?
  lastError       String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([appointmentRef, kind])
  @@index([status, scheduledSendAt])
  @@index([patientId])
}

model ClinicalHistoryEntry {
  id           String      @id @default(uuid())
  patientId    String
  patient      Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  specialistId String?
  specialist   Specialist? @relation(fields: [specialistId], references: [id], onDelete: SetNull)
  recordDate   DateTime    @db.Date
  diagnosis    String      @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([patientId, recordDate])
  @@index([specialistId])
}

/// Cita: paciente, especialista, fecha, franja horaria, estado, registro médico, motivo.
model Appointment {
  id              String            @id @default(uuid())
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  specialistId    String
  specialist      Specialist        @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  /// Consultorio asignado (ej. "Consultorio 1")
  consultorio     String            @default("Consultorio 1")
  /// Fecha del turno (solo día)
  appointmentDate DateTime          @db.Date
  /// Hora inicio "HH:mm" (24 h)
  startTime       String
  /// Hora fin "HH:mm"
  endTime         String
  status          AppointmentStatus @default(RESERVED)
  /// Monto abonado como anticipo cuando el estado es RESERVADO (seña / reserva).
  reservationDepositAmount Decimal? @db.Decimal(12, 2)
  medicalRecord   String?           @db.Text
  reasonForVisit  String?
  paymentMethod   AppointmentPaymentMethod?
  /// Pago combinado: [{ method, amount }, ...] (2+ ítems). Si está definido, `paymentMethod` suele ser null.
  paymentSplits   Json?
  /// Indica si el cobro de este turno ya fue efectivamente realizado
  paymentCompleted Boolean          @default(false)
  /// Fecha en la que se realizó el pago (si corresponde)
  paymentDate     DateTime?         @db.Date
  /// Fecha/hora en que LogoCen rindió este turno al especialista (solo aplica para TRANSFER_TO_SPECIALIST)
  specialistSettledAt DateTime?
  /// Confirmación del paciente para asistir (p. ej. vía recordatorio WhatsApp).
  patientConfirmedAt DateTime?
  patientConfirmationSource PatientConfirmationSource?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  payments        Payment[]

  @@index([specialistId, appointmentDate])
  @@index([patientConfirmedAt])
  @@index([consultorio, appointmentDate])
  @@index([appointmentDate])
}

/// Turno fijo semanal: una fila por paciente/especialista/día/hora; las ocurrencias se calculan al listar la agenda.
model FixedAppointmentSeries {
  id                    String     @id @default(uuid())
  patientId             String
  patient               Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  specialistId          String
  specialist            Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  consultorio           String
  weekday               Weekday
  startTime             String
  /// Solo para dibujar en el calendario (la duración real de la terapia puede variar).
  displayDurationMinutes Int       @default(60)
  effectiveFrom         DateTime   @db.Date
  effectiveUntil        DateTime?  @db.Date
  active                Boolean    @default(true)
  reasonForVisit        String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  skips                 FixedAppointmentSkip[]
  occurrences           FixedAppointmentOccurrence[]

  @@index([specialistId, weekday, active])
  @@index([patientId, active])
}

/// Datos de un día concreto de una serie fija (pago, estado, etc.). Solo se persiste cuando hay información que guardar.
model FixedAppointmentOccurrence {
  id                       String                    @id @default(uuid())
  seriesId                 String
  series                   FixedAppointmentSeries    @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  occurrenceDate           DateTime                  @db.Date
  status                   AppointmentStatus         @default(RESERVED)
  reservationDepositAmount Decimal?                  @db.Decimal(12, 2)
  paymentMethod            AppointmentPaymentMethod?
  paymentSplits            Json?
  paymentCompleted         Boolean                   @default(false)
  paymentDate              DateTime?                 @db.Date
  specialistSettledAt      DateTime?
  patientConfirmedAt       DateTime?
  patientConfirmationSource PatientConfirmationSource?
  medicalRecord            String?                   @db.Text
  reasonForVisit           String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  @@unique([seriesId, occurrenceDate])
  @@index([patientConfirmedAt])
  @@index([seriesId, occurrenceDate])
}

/// Cancela una sola fecha de una serie fija sin borrar la serie ni crear filas de Appointment.
model FixedAppointmentSkip {
  id        String                 @id @default(uuid())
  seriesId  String
  series    FixedAppointmentSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  skipDate  DateTime               @db.Date
  createdAt DateTime               @default(now())

  @@unique([seriesId, skipDate])
  @@index([seriesId])
}

model Payment {
  id            String        @id @default(uuid())
  appointmentId String
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  amount        Decimal       @db.Decimal(12, 2)
  currency      String        @default("ARS")
  status        PaymentStatus @default(PENDING)
  method        String?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([appointmentId])
}

model FinanceConfig {
  /// Singleton de configuración financiera global
  id                  String   @id @default("default")
  monthlyFixedExpense Decimal  @default(0) @db.Decimal(12, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model FinanceExpense {
  id          String           @id @default(uuid())
  type        FinanceExpenseType
  description String
  amount      Decimal          @db.Decimal(12, 2)
  expenseDate DateTime         @db.Date
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([expenseDate, type])
}
