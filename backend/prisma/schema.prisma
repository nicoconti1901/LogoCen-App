generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SPECIALIST
}

enum AppointmentStatus {
  RESERVED
  CONFIRMED
  ATTENDED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  role         Role
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  specialist   Specialist?
}

model Specialist {
  id               String        @id @default(uuid())
  userId           String        @unique
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String
  specialty        String
  /// URL de foto de perfil (p. ej. almacenamiento externo o data URL acotada)
  profilePhotoUrl  String?
  licenseNumber    String?
  phone            String?
  active           Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  appointments  Appointment[]
}

model Patient {
  id           String        @id @default(uuid())
  firstName    String
  lastName     String
  email        String
  phone        String?
  documentId   String?
  birthDate    DateTime?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

/// Cita: paciente, especialista, fecha, franja horaria, estado, registro médico, motivo.
model Appointment {
  id              String            @id @default(uuid())
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  specialistId    String
  specialist      Specialist        @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  /// Fecha del turno (solo día)
  appointmentDate DateTime          @db.Date
  /// Hora inicio "HH:mm" (24 h)
  startTime       String
  /// Hora fin "HH:mm"
  endTime         String
  status          AppointmentStatus @default(RESERVED)
  medicalRecord   String?           @db.Text
  reasonForVisit  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  payments        Payment[]

  @@index([specialistId, appointmentDate])
  @@index([appointmentDate])
}

model Payment {
  id            String        @id @default(uuid())
  appointmentId String
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  amount        Decimal       @db.Decimal(12, 2)
  currency      String        @default("ARS")
  status        PaymentStatus @default(PENDING)
  method        String?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([appointmentId])
}
